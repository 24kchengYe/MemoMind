"""
MemoMind Server - Hindsight embedded server with persistent memory.
Copy this file to /opt/hindsight-env/serve.py and fill in your API key.
"""
import time, signal, sys
from hindsight import HindsightServer

server = HindsightServer(
    llm_provider="openai",
    llm_model="qwen/qwen3.5-9b",                    # Cheap model for fact extraction
    llm_api_key="sk-or-v1-YOUR_OPENROUTER_KEY",      # <-- Replace with your OpenRouter key
    llm_base_url="https://openrouter.ai/api/v1",
    port=8888,
    host="0.0.0.0",
    mcp_enabled=True
)
server.start()
print(f"MemoMind running at {server.url}", flush=True)

def shutdown(sig, frame):
    server.stop()
    sys.exit(0)

signal.signal(signal.SIGTERM, shutdown)
signal.signal(signal.SIGINT, shutdown)

while True:
    time.sleep(3600)
